{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ynoTV",
  "version": "1.5.9",
  "identifier": "com.ynotv.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @ynotv/ui dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @ynotv/ui build",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "ynoTV",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "transparent": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGRERENzgyRkQ3MkE3REMKUldUY3AzTDlndGZkYjZhdVB0QmpTellTMUU3VGdTcXFORWlXbzduMWMrd2V2dk4rR2xKWW95T0kK",
      "endpoints": [
        "https://github.com/tbeezy/ynotv/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "deb",
      "rpm",
      "appimage",
      "dmg"
    ],
    "licenseFile": "../../../LICENSE",
    "externalBin": [
      "bin/mpv",
      "bin/ffmpeg"
    ],
    "resources": {},
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
